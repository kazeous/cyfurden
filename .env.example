# PostgreSQL is required for accounts and booth management.
DATABASE_URL="postgresql://cyfurden:change-me@127.0.0.1:55433/cyfurden"

# Generate at least 32 random bytes for production.
BETTER_AUTH_SECRET="replace-with-a-high-entropy-secret"
BETTER_AUTH_URL="http://localhost:3000"
# Comma-separated exact origins. Production example: https://cyfurden.kazeous.com
BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:3000"

# Optional locally; required to enable the Google button in production.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Sentry error monitoring. The DSN is intentionally public and must be available
# at both build time (for the browser bundle) and runtime (for server errors).
NEXT_PUBLIC_SENTRY_DSN=""
# Optional label such as production or staging; defaults to NODE_ENV when empty.
NEXT_PUBLIC_SENTRY_ENVIRONMENT=""

# Build-only credentials for uploading private source maps to Sentry. Leave all
# three empty to skip source-map generation/upload during local builds.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Public Oracle Object Storage delivery origin (no credentials and no trailing slash).
NEXT_PUBLIC_ORACLE_OBJECT_BASE_URL=""

# Server-only Oracle Object Storage S3-compatible upload settings.
# Create an OCI Customer Secret Key for this application; never expose these values
# through NEXT_PUBLIC_ variables. The endpoint override is optional for standard OCI.
ORACLE_OBJECT_STORAGE_NAMESPACE=""
ORACLE_OBJECT_STORAGE_REGION=""
ORACLE_OBJECT_STORAGE_BUCKET=""
ORACLE_OBJECT_STORAGE_ACCESS_KEY_ID=""
ORACLE_OBJECT_STORAGE_SECRET_ACCESS_KEY=""
ORACLE_OBJECT_STORAGE_S3_ENDPOINT=""
