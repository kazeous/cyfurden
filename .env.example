# PostgreSQL is required for accounts and booth management.
DATABASE_URL="postgresql://cyfurden:change-me@127.0.0.1:55433/cyfurden"

# Generate at least 32 random bytes for production.
BETTER_AUTH_SECRET="replace-with-a-high-entropy-secret"
